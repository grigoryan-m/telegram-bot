# ─── Telegram ─────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather

# ─── WeedeN REST API ──────────────────────────────────────────
# Base URL of your Odoo instance (no trailing slash)
ODOO_URL=https://your-odoo-instance.com
# Bearer token for POST /api/client/register  (auth=token)
ODOO_API_TOKEN=your_api_token_here

# ─── AI Assistant (Claude) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Manager Notifications ────────────────────────────────────
MANAGER_CHAT_ID=123456789
MANAGER_WORK_START=10
MANAGER_WORK_END=18

# ─── External Links ───────────────────────────────────────────
SOCIALS_URL=https://your-socials-landing.com
RECIPE_URL=https://your-recipe-partner.com

# ─── Analytics (optional) ─────────────────────────────────────
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your_ga4_api_secret
